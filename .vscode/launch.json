{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "${workspaceFolder}/docs"
      ],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"],
      "preLaunchTask": "npm: compile - extension"
    },
    {
      "name": "Run Extension (watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "${workspaceFolder}/docs"
      ],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"],
      "preLaunchTask": "npm: watch - extension"
    },

    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: invoice-flat (JSON → JSON)",
      "template": "${workspaceFolder}/docs/invoice-flat.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: sales-order-transform (JSON → JSON)",
      "template": "${workspaceFolder}/docs/sales-order-transform.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: person-transform (JSON → JSON)",
      "template": "${workspaceFolder}/docs/person-transform.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: order-to-xml (JSON → JSON)",
      "template": "${workspaceFolder}/docs/order-to-xml.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: email-notification (JSON → HTML)",
      "template": "${workspaceFolder}/docs/email-notification.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: customer-to-xml (JSON → XML)",
      "template": "${workspaceFolder}/docs/customer-to-xml.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Sample: shipping-label (JSON → plain text)",
      "template": "${workspaceFolder}/docs/shipping-label.liquid"
    }
  ]
}
